# =========================
# Sports Dashboard — Environment Variables
# =========================
# Copy this file to .env and customize as needed.
# Docker Compose reads .env from the project root automatically.

# =========================
# Mock Score API (FastAPI/Python)
# =========================
PORT=8000

# --- Basketball Simulation ---
TEAM_HOME=Lakers
TEAM_AWAY=Warriors
SCORE_INIT_HOME=0
SCORE_INIT_AWAY=0
QUARTER_SECONDS=720
TICK_SECONDS_MIN=10
TICK_SECONDS_MAX=60
HALFTIME_TICKS=3

# --- Soccer Simulation ---
SOCCER_TEAM_HOME=Barcelona
SOCCER_TEAM_AWAY=Real Madrid
SOCCER_HALF_MINUTES=45
SOCCER_HALFTIME_TICKS=3
SOCCER_HOME_ATTACK=80
SOCCER_HOME_DEFENSE=75
SOCCER_AWAY_ATTACK=72
SOCCER_AWAY_DEFENSE=70
SOCCER_HOME_ADVANTAGE=1.12

# =========================
# Go Backend (streaming-app-backend)
# =========================
MOCK_SCORE_API_URL=http://mock-score-api:8000/score

# =========================
# Next.js Frontend (streaming-app-frontend)
# =========================
# Used at build-time by the browser; must be the host-visible address
NEXT_PUBLIC_API_URL=http://localhost:8081
