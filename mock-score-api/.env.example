# Example environment variables for mock-score-api
# Copy this to .env and fill values for local development

# Port the FastAPI server listens on
PORT=8000

# Optional: override default team names
TEAM_HOME=Lakers
TEAM_AWAY=Warriors

# Initial scores
SCORE_INIT_HOME=0
SCORE_INIT_AWAY=0

# Timing / simulation settings
QUARTER_SECONDS=720
TICK_SECONDS_MIN=10
TICK_SECONDS_MAX=60
HALFTIME_TICKS=3

# Rules / limits
TIMEOUT_LIMIT=7
FOUL_LIMIT=6
